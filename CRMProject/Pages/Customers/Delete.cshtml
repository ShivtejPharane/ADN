@page
@model CRMProject.Pages.Customers.DeleteModel
@{
    ViewData["Title"] = "Delete Customer";
}

<h2 class="mt-4">Delete Customer</h2>

<div class="alert alert-danger">
    <strong>Warning:</strong> Are you sure you want to delete this customer? This action cannot be undone.
</div>

<div>
    <h4>Customer Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.Customer.Id</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Customer.Name</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Customer.Email</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Customer.Phone</dd>
    </dl>
    
    <form method="post">
        <input type="hidden" name="id" value="@Model.Customer.Id" />
        
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>