@page
@model CRMProject.Pages.Leads.DeleteModel
@{
    ViewData["Title"] = "Delete Lead";
}

<h1>Delete Lead</h1>

<h3 class="text-danger">Are you sure you want to delete this lead?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Lead.Name</dd>
        
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Lead.Email</dd>
        
        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Lead.Phone</dd>
        
        <dt class="col-sm-2">Company</dt>
        <dd class="col-sm-10">@Model.Lead.Company</dd>
        
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Lead.Status</dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Lead.Id" />
        <button type="submit" class="btn btn-danger">Delete</button> |
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
