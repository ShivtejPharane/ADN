@page
@model CRMProject.Pages.Tasks.DeleteModel
@{
    ViewData["Title"] = "Delete Task";
}

<h1>Delete Task</h1>

<h3 class="text-danger">Are you sure you want to delete this task?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.TaskItem.Title</dd>
        
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.TaskItem.Description</dd>
        
        <dt class="col-sm-2">Due Date</dt>
        <dd class="col-sm-10">@(Model.TaskItem.DueDate?.ToString("MM/dd/yyyy") ?? "-")</dd>
        
        <dt class="col-sm-2">Completed?</dt>
        <dd class="col-sm-10">@(Model.TaskItem.IsCompleted ? "Yes" : "No")</dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="TaskItem.Id" />
        <button type="submit" class="btn btn-danger">Delete</button> |
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
