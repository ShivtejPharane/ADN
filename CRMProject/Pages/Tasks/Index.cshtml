@page
@model CRMProject.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Tasks";
}

<h1>Tasks</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Task</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ListTasks)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    <strong>@item.Title</strong>
                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <br /><small class="text-muted">@item.Description</small>
                    }
                </td>
                <td>@(item.DueDate?.ToString("MM/dd/yyyy") ?? "-")</td>
                <td>
                    @if (item.IsCompleted)
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pending</span>
                    }
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
