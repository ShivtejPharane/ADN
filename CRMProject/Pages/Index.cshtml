@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center mt-5">
    <h1 class="display-4">Welcome to CRM Homepage</h1>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <h3 class="mt-4 text-success">You are logged in as @User.Identity.Name!</h3>
        
        <div class="row mt-5">
            <div class="col-md-4">
                <div class="card text-white bg-primary mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Total Customers</h5>
                        <p class="card-text display-6">@Model.TotalCustomers</p>
                        <a asp-page="/Customers/Index" class="btn btn-light mt-2">Manage Customers</a>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card text-white bg-info mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Total Leads</h5>
                        <p class="card-text display-6">@Model.TotalLeads</p>
                        <a asp-page="/Leads/Index" class="btn btn-light mt-2">Manage Leads</a>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card text-white bg-warning mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Active Tasks</h5>
                        <p class="card-text display-6">@Model.ActiveTasks</p>
                        <a asp-page="/Tasks/Index" class="btn btn-light mt-2">View Tasks</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card mx-auto mt-5" style="max-width: 400px;">
            <div class="card-body">
                <h3 class="card-title mb-4">Admin Login</h3>
                
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post">
                    <div class="mb-3 text-start">
                        <label class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" placeholder="Enter 'admin'" />
                    </div>
                    <div class="mb-3 text-start">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter 'password'" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>
            </div>
        </div>
    }
</div>